// prisma/schema.prisma

generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"

}

datasource db {
  provider = "postgresql"
}

// 1. СТРОГИЕ СТАТУСЫ ТОВАРА
enum ProductStatus {
  AVAILABLE
  RESERVED
  SOLD
}

// 2. СТАТУСЫ ЗАКАЗА
enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  CANCELLED
}


// 3. МОДЕЛЬ ТОВАРА (Искусство 1-of-1)
model Product {
  id                 String        @id @default(uuid())
  title              String
  slug               String        @unique
  description        String        @db.Text
  price              Int           // В копейках (1500000 = 15,000.00)
  
  status             ProductStatus @default(AVAILABLE)

  // ПРЕВЬЮ (Легкие изображения для списка товаров)
  thumbnailFront     String
  thumbnailBack      String

  // ГАЛЕРЕЯ (Массив тяжелых фото для страницы товара)
  gallery            String[]

  // ХАРАКТЕРИСТИКИ
  size               String
  materials          String?
  
  // МЕТАДАННЫЕ ДЛЯ CANVAS ДВИЖКА
  sequenceFolder     String        
  sequenceFrameCount Int           @default(174)

  // АНАЛИТИКА / ИЗБРАННОЕ
  favoriteCount      Int           @default(0)

// СВЯЗИ
  categoryId         String
  category           Category      @relation(fields: [categoryId], references: [id])
  
  orderId            String?
  order              Order?        @relation(fields: [orderId], references: [id])

  @@index([categoryId])

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status])
  @@index([slug])
}

// 4. МОДЕЛЬ ЗАКАЗА
model Order {
  id               String      @id @default(uuid())
  status           OrderStatus @default(PENDING)
  
  customerEmail    String?
  customerName     String?
  customerAddress  Json?       
  
  stripeSessionId  String?     @unique
  
  items            Product[]

  expiresAt        DateTime?   // Для очистки брони через 15 минут

  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@index([stripeSessionId])
}

// 5. МОДЕЛЬ КАТЕГОРИИ
model Category {
  id          String    @id @default(uuid())
  name        String    @unique // Например: "Футболки"
  slug        String    @unique // Например: "t-shirts"
  
  products    Product[] // Связь: в одной категории много товаров

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// 6. ГЛОБАЛЬНЫЕ НАСТРОЙКИ САЙТА (Singleton)
model SiteSettings {
  // Используем жестко заданный ID, чтобы всегда обращаться к одной и той же строке
  id                     String   @id @default("global") 
  
  heroSequenceFolder     String   @default("sequence")
  heroSequenceFrameCount Int      @default(174)
  
  updatedAt              DateTime @updatedAt
}